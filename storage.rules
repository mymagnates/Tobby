rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(uid) {
      return isSignedIn() && request.auth.uid == uid;
    }

    // Posts media: signed-in users can view, only owner can modify.
    match /media/posts/{uid}/{allPaths=**} {
      allow read: if isSignedIn();
      allow write: if isOwner(uid);
    }

    // App uploads used by PM/PO/SP flows.
    match /images/{allPaths=**} {
      allow read, write: if isSignedIn();
    }

    match /properties/{allPaths=**} {
      allow read, write: if isSignedIn();
    }

    match /leases/{allPaths=**} {
      allow read, write: if isSignedIn();
    }

    // Keep everything else private unless explicitly added later.
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
